root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Standard indentation for general files
indent_style = tab
indent_size = 4

# Godot-specific configuration
[*.gd]
indent_style = tab
indent_size = 4

# JSON and Markdown (VS Code preferred)
[*.{json,md}]
indent_style = space
indent_size = 2
